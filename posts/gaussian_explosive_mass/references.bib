@article{vanbuijtenen-1980,
title = {Calculation of the amount of gas in the explosive region of a vapour cloud released in the atmosphere},
journal = {Journal of Hazardous Materials},
volume = {3},
number = {3},
pages = {201-220},
year = {1980},
issn = {0304-3894},
doi = {10.1016/0304-3894(80)85001-1},
author = {C.J.P. {Van Buijtenen}},
abstract = {Formulae were derived and calculations made for the amount of gas in the explosive region of a vapour cloud or plume. It appears that, for an instantaneous source, a large fraction of the total amount released (e.g. 50% for methane) can be in the explosive region, irrespective of source strength and meteorological conditions. On the other hand, for a continuous source, the amount in the explosive region is strongly dependent on source strength and meteorological conditions. To assist in the hazard analysis, a computer program was written to calculate the concentration as a function of time for a quasi-instantaneous spill of LNG on water.}
}

